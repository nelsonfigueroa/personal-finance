<div class="container">

<%= render partial: 'layouts/notifications' %>

<div>
    <div>
        <p class="net-worth-label">net worth</p>
        <div class="net-worth-amount"><%= humanized_money_with_symbol @net_worth %></div>
        <p class="net-worth-date">as of <%= Time.now.getlocal.strftime('%Y-%m-%d') %></p>
    </div>
</div>

<%= line_chart net_worth_graph_path,
    colors: ["#00c200"], prefix: "$",
    thousands: ",",
    spanGaps: true,
    loading: "Loading...",
    messages: {empty: "No statements recorded."},
    download: {filename: "net-worth", background: "#0a0a0a"},
    library: {
      scales: {
        x: { ticks: { color: "#666", font: { family: "IBM Plex Mono" } }, grid: { color: "#1a1a1a" }, border: { color: "#2a2a2a" } },
        y: { ticks: { color: "#666", font: { family: "IBM Plex Mono" } }, grid: { color: "#1a1a1a" }, border: { color: "#2a2a2a" } }
      },
      plugins: { legend: { labels: { color: "#666", font: { family: "IBM Plex Mono" } } } },
      elements: { point: { radius: 2, hoverRadius: 4 }, line: { tension: 0, borderWidth: 2 } }
    } %>

<br>

<section>
  <h2>Account Balances</h2>
  <br>

  <% if @accounts.empty? %>
    <p>No existing accounts. Create one!</p>
  <% else %>
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Latest Statement</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% @accounts.each do |account| %>
          <tr>
          <td><%= link_to account.name, account %></td>
          <% if account.statements.order(:date).last %>
            <td><%= humanized_money_with_symbol account.statements.order(:date).last.balance %></td>
            <td><%= account.statements.order(:date).last.date.to_formatted_s(:long) %></td>
          <% else %>
            <td><i>No recorded statements</i></td>
            <td></td>
          <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</section>

<br>

<p>Overview for <%= @selected_year %></p>

<div>
    <%= form_tag dashboard_path, method: :get do %>
        <%= select_tag :year, options_for_select(@years_for_switcher, @selected_year), include_blank: false %>
        <%= submit_tag "Filter by year" %>
    <% end %>
</div>

<br>

<section>
  <h2>Income vs Expenses (<%= @selected_year %>)</h2>
  <p>Percentage of income spent on expenses: <%= @income_vs_expenses_percentage %>%</p>
  <%= ascii_bar(
    { "Income" => @total_yearly_income, "Expenses" => @yearly_expenses },
    colors: { "Income" => "ascii-bar-green", "Expenses" => "ascii-bar-dim" }
  ) %>

  <br>

  <h2>Income vs Rent (<%= @selected_year %>)</h2>
  <% if @rent_to_income_percentage %>
    <p>Percentage of income spent on rent: <%= @rent_to_income_percentage %>% (Try to keep this at 30% or under!)</p>
  <% end %>
  <%= ascii_bar(
    { "Income" => @total_yearly_income, "Rent" => @yearly_rent },
    colors: { "Income" => "ascii-bar-green", "Rent" => "ascii-bar-dim" }
  ) %>

  <br>

  <h2>Income (<%= @selected_year %>)</h2>
  <small>Where your money comes from</small>
  <%= ascii_bar(@income_by_category, show_percent: true, total: @total_yearly_income) %>

  <br>

  <h2>Expenses (<%= @selected_year %>)</h2>
  <small>Where your money is being spent</small>
  <% expenses_by_category = @transactions_by_category_per_year[@selected_year] || {} %>
  <% expenses_hash = expenses_by_category.transform_keys { |cat| cat.respond_to?(:name) ? cat.name : cat.to_s } %>
  <%= ascii_bar(expenses_hash, show_percent: true, total: @yearly_expenses) %>

  <br>

  <h2>Yearly Overview (<%= @selected_year %>)</h2>
  <table>
    <thead>
      <tr>
        <th colspan="2"><%= @selected_year %></th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>Income</td>
        <td><%= humanized_money_with_symbol @total_yearly_income %></td>
      </tr>
      <tr>
        <td>Expenses</td>
        <td><%= humanized_money_with_symbol @yearly_expenses %></td>
      </tr>
      <tr>
        <td>Interest Earnings</td>
        <td><%= humanized_money_with_symbol @yearly_interest %></td>
      </tr>
    </tbody>
  </table>

  <br>

  <% if @transactions.empty? %>
    <p>(Add some transactions to show yearly expenses by category)</p>
  <% else %>
    <h2>Yearly Expenses by Category (<%= @selected_year %>)</h2>
    <% @transactions_by_category_per_year.keys.each do |year| %>
    <table>
      <thead>
        <tr>
          <th colspan="2"><%= year %></th>
        </tr>
      </thead>
      <tbody>
        <% @transactions_by_category_per_year[year].each do |category, amount| %>
          <tr>
          <td><a href="<%= category_path(category.id) %>"><span style="color:<%= category.color %>;"><%= category.name %></span></a></td>
          <td><%= humanized_money_with_symbol amount %></td>
          </tr>
        <% end %>
    <% end %>
      </tbody>
    </table>
  <% end %>
</section>
</div>
